# Copy to .env and fill in
TRADIER_TOKEN=your_tradier_api_token_here
TRADIER_BASE_URL=https://sandbox.tradier.com/v1
# For live trading data use: https://api.tradier.com/v1

# Scanner worker — chain data refreshed every 2 minutes
SCAN_INTERVAL_SECONDS=120
# Spot price poll fallback cadence when WebSocket is unavailable (seconds)
STREAM_POLL_SECONDS=5

# Risk-free rate for greeks fallback math (annualized)
RISK_FREE_RATE=0.045

# CORS: comma-separated origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQLite snapshot DB path
SNAPSHOT_DB=./snapshots.db

# Telegram alerts (optional)
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Finnhub (optional — for NEWS tab + real earnings data)
# Free API key from https://finnhub.io/register
FINNHUB_API_KEY=

# Flow alert filter (May 6 2026 spam-reduction)
# OFF   — legacy gate (HIGH/$5M/OTM/max 2 per cycle), no spam reduction
# LIGHT — drop LOW unless sweep/$5M; drop NEUTRAL+HARD; 5/hr per-ticker cap
# FULL  — LIGHT + multi-leg cluster collapser (≥3 same-ticker in 60s → summary)
# Backtest on May 6 data: 1,267 → ~270 alerts (-78%) at FULL.
FLOW_ALERT_FILTER_LEVEL=LIGHT
